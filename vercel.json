{
  "version": 2,
  "buildCommand": "npm install && cd backend && npm install && npm run build && cd ../frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": "backend/dist/**"
    }
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/health",     "destination": "/api/index" },
    { "source": "/:path*",     "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/market-cycle",
      "schedule": "0 4 * * 1-5"
    }
  ]
}
