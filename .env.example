# ── LLM ─────────────────────────────────────────────────────────────────────
# Groq API — free at https://console.groq.com (fallback when Gemini rate-limits)
groq_key=gsk_...

# Gemini API — free at https://aistudio.google.com/app/apikey
# Used for: news sentiment, TARS chat, RAG embeddings (text-embedding-004)
GEMINI_API_KEY=AIza...

# ── Database ─────────────────────────────────────────────────────────────────
# Turso Database — free at https://turso.tech
turso_region=libsql://your-db.turso.io
turso_sb_key=eyJ...

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWT secret — min 32 random chars (generate: openssl rand -base64 32)
JWT_SECRET=replace-with-32-plus-random-chars

# ── CORS ─────────────────────────────────────────────────────────────────────
# Frontend origin — no trailing slash
FRONTEND_URL=https://your-app.vercel.app

# ── Cache (optional — in-memory used if not set) ──────────────────────────────
# Vercel KV — set automatically when KV store is added in Vercel dashboard
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...

# Upstash Redis — alternative to Vercel KV (free at https://upstash.com)
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# ── Cron auth ────────────────────────────────────────────────────────────────
# Secret sent by cron-job.org in Authorization header for admin/cron endpoints
CRON_SECRET=replace-with-strong-random-secret
